        usecase (Xóa lịch sử chat) as UC23
        usecase (Đăng xuất) as UC24
    }
    
    ' ===== ADMIN (Hồng) =====
    package "Admin" #F8D7DA {
        usecase (Xem thống kê) as UC25
        usecase (Thay đổi role) as UC26
        usecase (Quản lý người dùng) as UC27
        usecase (Xóa user) as UC28
        usecase (Quản lý điểm đến) as UC29
        usecase (Sửa điểm đến) as UC30
        usecase (Thêm điểm đến) as UC31
        usecase (Xóa điểm đến) as UC32
        usecase (Quản lý đánh giá) as UC33
        usecase (Xóa đánh giá) as UC34
        usecase (Duyệt đánh giá) as UC35
    }
}

