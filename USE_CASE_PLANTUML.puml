@startuml USE_CASE_TRAVELAI

title SƠ ĐỒ USE CASE - TRAVELAI

left to right direction

' Actors
actor "Khách" as Guest
actor "User" as User
actor "Admin" as Admin

' System boundary
rectangle "Hệ thống TravelAI" {
    
    ' ===== KHÁCH (Vàng) =====
    package "Khách" #FFF4CC {
        usecase (Đăng nhập) as UC1
        usecase (Đăng ký) as UC2
        usecase (Xem điểm đến) as UC3
        usecase (Xem chi tiết) as UC4
        usecase (Lọc theo danh mục) as UC5
        usecase (Tìm kiếm) as UC6
        usecase (Chat với AI) as UC7
        usecase (Nhận gợi ý) as UC8
        usecase (Xem thời tiết) as UC9
        usecase (Xem ẩm thực) as UC10
        usecase (Xem bản đồ) as UC11
        usecase (Xem đánh giá) as UC12
    }
    
    ' ===== USER (Xanh lá) =====
    package "User" #D4EDDA {
        usecase (Cập nhật profile) as UC13
        usecase (Cập nhật sở thích) as UC14
        usecase (Lưu điểm đến) as UC15
        usecase (Xem đã lưu) as UC16
        usecase (Tạo lịch trình) as UC17
        usecase (Xem lịch sử chat) as UC18
